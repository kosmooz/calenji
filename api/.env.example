# Database (use Docker internal network in production)
DATABASE_URL=postgresql://socialapp:CHANGE_ME_STRONG_PASSWORD@postgres:5432/socialapp

# JWT (generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# Environment
NODE_ENV=production

# Frontend URL (your production domain)
FRONTEND_URL=https://yourdomain.com

# Token encryption (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# Meta / Facebook API
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3005/dashboard/reseaux/callback

# Public URL for serving media to Meta API
PUBLIC_URL=http://localhost:3004

# WordPress media hosting (for Meta API public URLs)
WORDPRESS_API_URL=
WORDPRESS_AUTH_TOKEN=
